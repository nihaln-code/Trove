# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/trove

# Used to sign JWT access/refresh tokens (min 32 chars)
SECRET_KEY=your-secret-key-at-least-32-chars-long

# Google OAuth client ID (used for Google Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# TMDB API key (used to fetch movie/show content)
TMDB_API_KEY=your-tmdb-api-key

# OpenAI API key (used to generate recommendations)
OPENAI_API_KEY=sk-your-openai-api-key

# URL of the frontend, used for CORS
FRONTEND_URL=http://localhost:5173

# Optional overrides (defaults shown)
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30
