# Used only by docker-compose to provision the postgres container
# and to inject VITE_GOOGLE_CLIENT_ID at frontend build time.
POSTGRES_USER=trove
POSTGRES_PASSWORD=change-me
POSTGRES_DB=trove

# Same value as frontend/.env's VITE_GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
